#!/usr/bin/env bash
# Usage:
#   github-homepage-list -u <username>                    # all repos (forks excluded)
#   github-homepage-list -u <username> -v public          # only public
#   github-homepage-list -u <username> -v private         # only private
#   github-homepage-list -u <username> -F                 # include forks
#   github-homepage-list -u <username> -r                 # output repo URLs (github.com/owner/repo)
#   github-homepage-list -u <username> -o                 # also save URLs to auto-named file in $PWD
#   github-homepage-list -u <username> -o out.txt         # also save URLs to a specific file
#   github-homepage-list --help                           # show help
#
# Lists repositories that have a non-empty website/homepage URL. Default mode:
# homepage URLs. With -r / --repo-url: repository URLs instead.
# By default prints to stdout only. Pass -o to also save a file — bare -o
# generates <PWD>/homepages-<user>_<timestamp>.txt, -o <path> uses that path.
#
# Requires: gh CLI (authenticated)

set -u

GH_USER=""
VISIBILITY="all"
INCLUDE_FORKS=0
OUTPUT_FILE=""
OUTPUT_MODE="homepage"   # homepage | repo

show_usage() {
    sed -n '2,/^$/p' "$0" | sed -E 's/^# ?//'
}

if [[ $# -eq 0 && -t 0 ]]; then
    show_usage
    exit 0
fi

while [[ $# -gt 0 ]]; do
    case "$1" in
        -u|--user)
            [[ -z "${2:-}" ]] && { echo "ERROR: --user requires a username" >&2; exit 1; }
            GH_USER="$2"; shift 2 ;;
        -v|--visibility)
            [[ -z "${2:-}" ]] && { echo "ERROR: --visibility requires a value" >&2; exit 1; }
            VISIBILITY="$2"; shift 2 ;;
        -F|--include-forks)
            INCLUDE_FORKS=1; shift ;;
        -r|--repo-url)
            OUTPUT_MODE="repo"; shift ;;
        -o|--output)
            if [[ -z "${2:-}" || "${2:-}" == -* ]]; then
                OUTPUT_FILE="__AUTO__"; shift 1
            else
                OUTPUT_FILE="$2"; shift 2
            fi ;;
        -h|--help)
            show_usage; exit 0 ;;
        *)
            echo "Unknown argument: $1 (use --help)" >&2; exit 1 ;;
    esac
done

if [[ -z "$GH_USER" ]]; then
    echo "ERROR: -u <user> is required" >&2
    show_usage
    exit 1
fi

if ! command -v gh > /dev/null 2>&1; then
    echo "ERROR: gh CLI not found. Install with: brew install gh" >&2
    exit 1
fi

case "$VISIBILITY" in
    public|private|all) ;;
    *) echo "ERROR: invalid visibility '$VISIBILITY' (use: public, private, all)" >&2; exit 1 ;;
esac

if [[ "$OUTPUT_FILE" == "__AUTO__" ]]; then
    TIMESTAMP="$(date +%Y-%m-%d_%H-%M-%S)"
    if [[ "$OUTPUT_MODE" == "homepage" ]]; then
        OUTPUT_FILE="$PWD/homepages-$GH_USER""_$TIMESTAMP.txt"
    else
        OUTPUT_FILE="$PWD/homepages-repos-$GH_USER""_$TIMESTAMP.txt"
    fi
fi

# colors (tty only)
if [[ -t 1 ]]; then
    C_RESET=$'\033[0m'; C_BOLD=$'\033[1m'
    C_GREEN=$'\033[32m'; C_DIM=$'\033[90m'
    C_YELLOW=$'\033[33m'; C_BLUE=$'\033[94m'; C_BROWN=$'\033[38;5;94m'
else
    C_RESET=""; C_BOLD=""; C_GREEN=""; C_DIM=""
    C_YELLOW=""; C_BLUE=""; C_BROWN=""
fi

vis_args=()
[[ "$VISIBILITY" != "all" ]] && vis_args=(--visibility "$VISIBILITY")

jq_filter='.[]'
[[ "$INCLUDE_FORKS" == "0" ]] && jq_filter='.[] | select(.isFork==false)'
jq_filter="$jq_filter | select(.homepageUrl != null and .homepageUrl != \"\") | [.nameWithOwner, .homepageUrl, (.visibility | ascii_downcase), (.isFork|tostring), (.isArchived|tostring)] | @tsv"

echo "${C_BOLD}User:${C_RESET}       $GH_USER"
echo "${C_BOLD}Visibility:${C_RESET} $VISIBILITY"
echo "${C_BOLD}Forks:${C_RESET}      $([[ $INCLUDE_FORKS == 1 ]] && echo included || echo excluded)"
echo "${C_BOLD}Mode:${C_RESET}       $OUTPUT_MODE"
[[ -n "$OUTPUT_FILE" ]] && echo "${C_BOLD}Output:${C_RESET}     $OUTPUT_FILE"
echo

# Fetch all repos with homepage in one API call (no per-repo roundtrips)
results=$(gh repo list "$GH_USER" "${vis_args[@]}" --limit 1000 \
    --json nameWithOwner,isFork,isArchived,visibility,homepageUrl --jq "$jq_filter")

total=$(gh repo list "$GH_USER" "${vis_args[@]}" --limit 1000 \
    --json nameWithOwner,isFork --jq "$(
        [[ "$INCLUDE_FORKS" == "0" ]] && echo '[.[] | select(.isFork==false)] | length' || echo 'length'
    )")

if [[ -z "$results" ]]; then
    echo "No repos with a homepage set."
    [[ -n "$OUTPUT_FILE" ]] && : > "$OUTPUT_FILE"
    exit 0
fi

# pretty print (sorted by slug)
while IFS=$'\t' read -r slug url vis is_fork is_archived; do
    [[ -z "$slug" ]] && continue
    badges=""
    [[ "$vis" == "private" ]] && badges="$badges ${C_YELLOW}[🔐 private]${C_RESET}"
    [[ "$is_fork" == "true" ]] && badges="$badges ${C_BLUE}[🍴 fork]${C_RESET}"
    [[ "$is_archived" == "true" ]] && badges="$badges ${C_BROWN}[📦 archived]${C_RESET}"
    printf "${C_GREEN}✓${C_RESET} %-50s ${C_DIM}→${C_RESET} %s%s\n" "$slug" "$url" "$badges"
done <<< "$(echo "$results" | sort)"

# Build unique URL list (slug = col 1, homepage = col 2)
if [[ "$OUTPUT_MODE" == "repo" ]]; then
    urls=$(echo "$results" | cut -f1 | grep -v '^$' | sort -u \
        | awk '{print "https://github.com/" $0}')
else
    urls=$(echo "$results" | cut -f2 | grep -v '^$' | sort -u)
fi

found=$(echo "$urls" | grep -c . || true)
echo
echo "${C_BOLD}Found $found/$total repos with a homepage set.${C_RESET}"

if [[ -n "$OUTPUT_FILE" ]]; then
    echo "$urls" > "$OUTPUT_FILE"
    echo "Written to: $OUTPUT_FILE"
fi
