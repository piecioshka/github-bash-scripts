#!/usr/bin/env bash
# Usage:
#   github-repos-scan-secrets -u <username>                       # scan non-fork repos of a user
#   github-repos-scan-secrets -u <username> -v public             # only public
#   github-repos-scan-secrets -u <username> -v private            # only private
#   github-repos-scan-secrets -u <username> -F                    # include forks
#   github-repos-scan-secrets -f repos.txt                        # repos from a file
#   echo "https://github.com/o/r" | github-repos-scan-secrets     # repos from stdin
#   github-repos-scan-secrets owner/repo another-owner/repo       # positional slugs
#   github-repos-scan-secrets --help                              # show help
#
# For each repo:
#   1. clone history into a temporary directory
#   2. run `gitleaks detect` on the full history
#   3. search `git log -p --all` with a secret grep pattern
#   4. save reports to <RESULTS_DIR>/<owner>__<repo>/
#   5. clean up the clone
#
# Env:
#   RESULTS_DIR    reports directory (default: $PWD/scan-results)
#   GREP_PATTERN   regex for grep (default: secret|password|token|api_key|…)
#   CONCURRENCY    how many repos to scan in parallel (default: 4)
#
# Requires: git, gitleaks (brew install gitleaks); gh CLI only for -u

set -u

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
RESULTS_DIR="${RESULTS_DIR:-$PWD/scan-results}"
CLONE_DIR="$(mktemp -d -t scan-secrets.XXXXXX)"
RESULTS_TSV="$(mktemp -t scan-secrets-results.XXXXXX)"
GREP_PATTERN="${GREP_PATTERN:-secret|password|passwd|token|api[_-]?key|private[_-]?key|aws[_-]?access|bearer}"
CONCURRENCY="${CONCURRENCY:-4}"

trap 'rm -rf "$CLONE_DIR"; rm -f "$RESULTS_TSV"' EXIT INT TERM

show_usage() {
    sed -n '2,/^$/p' "$0" | sed -E 's/^# ?//'
}

GH_USER=""
VISIBILITY="all"
INCLUDE_FORKS=0
INPUT_FILE=""
POSITIONAL=()

if [[ $# -eq 0 && -t 0 ]]; then
    show_usage
    exit 0
fi

while [[ $# -gt 0 ]]; do
    case "$1" in
        -u|--user)
            [[ -z "${2:-}" ]] && { echo "ERROR: --user requires a value" >&2; exit 1; }
            GH_USER="$2"; shift 2 ;;
        -v|--visibility)
            [[ -z "${2:-}" ]] && { echo "ERROR: --visibility requires a value" >&2; exit 1; }
            VISIBILITY="$2"; shift 2 ;;
        -F|--include-forks)
            INCLUDE_FORKS=1; shift ;;
        -f|--file)
            [[ -z "${2:-}" ]] && { echo "ERROR: --file requires a path" >&2; exit 1; }
            INPUT_FILE="$2"; shift 2 ;;
        -h|--help)
            show_usage; exit 0 ;;
        -*)
            echo "Unknown flag: $1 (use --help)" >&2; exit 1 ;;
        *)
            POSITIONAL+=("$1"); shift ;;
    esac
done

if ! command -v git > /dev/null 2>&1; then
    echo "ERROR: git is not installed. Install with: brew install git" >&2
    exit 1
fi
if ! command -v gitleaks > /dev/null 2>&1; then
    echo "ERROR: gitleaks is not installed. Install with: brew install gitleaks" >&2
    exit 1
fi

case "$VISIBILITY" in
    public|private|all) ;;
    *) echo "ERROR: invalid visibility '$VISIBILITY' (use: public, private, all)" >&2; exit 1 ;;
esac

# colors (tty only)
if [[ -t 1 ]]; then
    C_RESET=$'\033[0m'; C_BOLD=$'\033[1m'
    C_GREEN=$'\033[32m'; C_YELLOW=$'\033[33m'
    C_RED=$'\033[31m'; C_DIM=$'\033[90m'
else
    C_RESET=""; C_BOLD=""; C_GREEN=""; C_YELLOW=""; C_RED=""; C_DIM=""
fi

paint_status() {
    local status="$1"
    local padded
    printf -v padded "%-6s" "$status"
    case "$status" in
        OK)   printf "%s%s%s" "$C_GREEN"  "$padded" "$C_RESET" ;;
        WARN) printf "%s%s%s" "$C_YELLOW" "$padded" "$C_RESET" ;;
        FAIL) printf "%s%s%s" "$C_RED"    "$padded" "$C_RESET" ;;
        SKIP) printf "%s%s%s" "$C_DIM"    "$padded" "$C_RESET" ;;
        *)    printf "%s" "$padded" ;;
    esac
}

print_row() {
    local status="$1"
    local repo="$2"
    local leaks="${3:--}"
    local grep_n="${4:--}"
    local details="${5:-}"
    printf "%s  %-45s  %8s  %10s  %s\n" \
        "$(paint_status "$status")" "$repo" "$leaks" "$grep_n" "$details"
}

print_header() {
    printf "%s%-6s  %-45s  %8s  %10s  %s%s\n" \
        "$C_BOLD" "STATUS" "REPO" "GITLEAKS" "GREP" "DETAILS" "$C_RESET"
    printf "%s\n" "$(printf '%.0s-' {1..100})"
}

# --- slug normalization ---
to_slug() {
    local input="$1"
    input="${input#"${input%%[![:space:]]*}"}"
    input="${input%"${input##*[![:space:]]}"}"
    if [[ "$input" =~ ^https?://github\.com/([^/]+)/([^/]+) ]]; then
        local repo="${BASH_REMATCH[2]%.git}"
        echo "${BASH_REMATCH[1]}/${repo%/}"
        return
    fi
    # allow plain owner/repo
    if [[ "$input" == */* ]]; then
        echo "${input%.git}"
        return
    fi
    echo ""
}

# --- collect slugs ---
collect_slugs() {
    local slugs=()

    # 1. positional args
    local arg
    for arg in "${POSITIONAL[@]+"${POSITIONAL[@]}"}"; do
        local s
        s=$(to_slug "$arg")
        [[ -n "$s" ]] && slugs+=("$s")
    done

    # 2. file
    if [[ -n "$INPUT_FILE" ]]; then
        if [[ ! -f "$INPUT_FILE" ]]; then
            echo "ERROR: file does not exist: $INPUT_FILE" >&2
            exit 1
        fi
        echo "${C_BOLD}Source:${C_RESET} file $INPUT_FILE" >&2
        while IFS= read -r line; do
            [[ "$line" =~ ^[[:space:]]*(#|$) ]] && continue
            local s
            s=$(to_slug "$line")
            [[ -n "$s" ]] && slugs+=("$s")
        done < "$INPUT_FILE"
    fi

    # 3. user (gh)
    if [[ -n "$GH_USER" ]]; then
        if ! command -v gh > /dev/null 2>&1; then
            echo "ERROR: gh CLI not found. Install with: brew install gh" >&2
            exit 1
        fi
        local vis_args=()
        [[ "$VISIBILITY" != "all" ]] && vis_args=(--visibility "$VISIBILITY")
        local jq_filter='.[]'
        [[ "$INCLUDE_FORKS" == "0" ]] && jq_filter='.[] | select(.isFork==false)'
        jq_filter="$jq_filter | .nameWithOwner"

        local note="(forks excluded)"
        [[ "$INCLUDE_FORKS" == "1" ]] && note="(forks included)"
        echo "${C_BOLD}Source:${C_RESET} gh repo list $GH_USER --visibility $VISIBILITY $note" >&2

        while IFS= read -r slug; do
            [[ -n "$slug" ]] && slugs+=("$slug")
        done < <(gh repo list "$GH_USER" "${vis_args[@]}" --limit 1000 \
            --json nameWithOwner,isFork --jq "$jq_filter")
    fi

    # 4. stdin (only if nothing else provided yet)
    if [[ ${#slugs[@]} -eq 0 && ! -t 0 ]]; then
        echo "${C_BOLD}Source:${C_RESET} stdin" >&2
        while IFS= read -r line; do
            [[ "$line" =~ ^[[:space:]]*(#|$) ]] && continue
            local s
            s=$(to_slug "$line")
            [[ -n "$s" ]] && slugs+=("$s")
        done
    fi

    # dedupe
    printf "%s\n" "${slugs[@]+"${slugs[@]}"}" | awk '!seen[$0]++'
}

# --- scan a single repo (safe for parallel execution) ---
# Writes a pipe-separated result tuple to $RESULTS_TSV (O_APPEND, atomic for
# small writes) and prints the formatted row to stdout with a single printf
# (also atomic for short lines).
scan_repo() {
    local slug="$1"

    if [[ -z "$slug" || "$slug" != */* ]]; then
        print_row "SKIP" "$slug" "-" "-" "invalid slug"
        printf "SKIP|%s|invalid slug|-|-\n" "$slug" >> "$RESULTS_TSV"
        return
    fi

    local safe_name="${slug//\//__}"
    local out_dir="$RESULTS_DIR/$safe_name"
    local repo_dir="$CLONE_DIR/$safe_name"
    mkdir -p "$out_dir"

    if ! git clone --quiet "https://github.com/$slug.git" "$repo_dir" \
            2>"$out_dir/clone.err"; then
        print_row "FAIL" "$slug" "-" "-" "clone failed → $out_dir/clone.err"
        printf "FAIL|%s|clone failed → %s|-|-\n" "$slug" "$out_dir/clone.err" >> "$RESULTS_TSV"
        return
    fi

    local leaks_count=0
    local grep_count=0

    NO_COLOR=1 gitleaks detect \
        --source "$repo_dir" \
        --report-format json \
        --report-path "$out_dir/gitleaks.json" \
        --redact \
        --no-banner \
        --no-color \
        > "$out_dir/gitleaks.stdout" 2>&1 || true

    if [[ -s "$out_dir/gitleaks.json" ]]; then
        leaks_count=$(grep -c '"RuleID"' "$out_dir/gitleaks.json" 2>/dev/null)
        leaks_count=${leaks_count:-0}
    fi

    (cd "$repo_dir" && git log -p --all 2>/dev/null) \
        | grep -iE "$GREP_PATTERN" \
        > "$out_dir/grep-matches.txt" 2>/dev/null || true

    if [[ -s "$out_dir/grep-matches.txt" ]]; then
        grep_count=$(wc -l < "$out_dir/grep-matches.txt" | tr -d ' ')
    fi

    rm -rf "$repo_dir"

    if (( leaks_count > 0 || grep_count > 0 )); then
        print_row "WARN" "$slug" "$leaks_count" "$grep_count" "$out_dir"
        printf "WARN|%s|%s|%s|%s\n" "$slug" "$out_dir" "$leaks_count" "$grep_count" >> "$RESULTS_TSV"
    else
        print_row "OK" "$slug" "$leaks_count" "$grep_count" ""
        printf "OK|%s||%s|%s\n" "$slug" "$leaks_count" "$grep_count" >> "$RESULTS_TSV"
    fi
}

# Export everything the worker subshell needs
export -f paint_status print_row scan_repo
export C_RESET C_BOLD C_GREEN C_YELLOW C_RED C_DIM
export CLONE_DIR RESULTS_DIR RESULTS_TSV GREP_PATTERN

# --- summary (reads $RESULTS_TSV populated by parallel workers) ---
print_summary() {
    local ok=0 warn=0 fail=0 skip=0
    local line status
    while IFS= read -r line; do
        [[ -z "$line" ]] && continue
        status="${line%%|*}"
        case "$status" in
            OK)   ok=$((ok + 1)) ;;
            WARN) warn=$((warn + 1)) ;;
            FAIL) fail=$((fail + 1)) ;;
            SKIP) skip=$((skip + 1)) ;;
        esac
    done < "$RESULTS_TSV"
    local total=$((ok + warn + fail + skip))

    echo
    echo "${C_BOLD}Summary:${C_RESET}"
    printf "  %s%-5s%s  %d\n" "$C_GREEN"  "OK"    "$C_RESET" "$ok"
    printf "  %s%-5s%s  %d\n" "$C_YELLOW" "WARN"  "$C_RESET" "$warn"
    printf "  %s%-5s%s  %d\n" "$C_RED"    "FAIL"  "$C_RESET" "$fail"
    printf "  %s%-5s%s  %d\n" "$C_DIM"    "SKIP"  "$C_RESET" "$skip"
    printf "  %sTOTAL%s  %d\n" "$C_BOLD"  "$C_RESET" "$total"

    if (( warn + fail > 0 )); then
        echo
        echo "${C_BOLD}Repositories that need attention:${C_RESET}"
        # FAIL first, then WARN, both sorted by slug
        (
            awk -F'|' '$1=="FAIL"' "$RESULTS_TSV" | sort -t'|' -k2
            awk -F'|' '$1=="WARN"' "$RESULTS_TSV" | sort -t'|' -k2
        ) | while IFS='|' read -r status slug details leaks grep_n; do
            printf "  %s  %-45s  %s\n" "$(paint_status "$status")" "$slug" "${details:--}"
        done
    fi
}

# --- main ---
mapfile -t SLUGS < <(collect_slugs)

if [[ ${#SLUGS[@]} -eq 0 ]]; then
    echo "No repos to scan." >&2
    show_usage
    exit 1
fi

mkdir -p "$RESULTS_DIR"
: > "$RESULTS_TSV"

echo "${C_BOLD}Results:${C_RESET}     $RESULTS_DIR"
echo "${C_BOLD}Tmp:${C_RESET}         $CLONE_DIR"
echo "${C_BOLD}Repos:${C_RESET}       ${#SLUGS[@]}"
echo "${C_BOLD}Concurrency:${C_RESET} $CONCURRENCY"
echo
print_header

printf "%s\n" "${SLUGS[@]}" \
    | xargs -n 1 -P "$CONCURRENCY" -I {} bash -c 'scan_repo "$@"' _ {}

print_summary
echo
echo "Done. Reports in: $RESULTS_DIR"
