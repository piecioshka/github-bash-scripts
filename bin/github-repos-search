#!/usr/bin/env bash
# Usage:
#   github-repos-search -u <user> -q <query>                  # search all repos
#   github-repos-search -u <user> -q <query> -v public        # only public
#   github-repos-search -u <user> -q <query> -v private       # only private
#   github-repos-search -u <user> -q <query> -F               # include forks
#   github-repos-search -u <user> -q <query> -c               # case-sensitive
#   github-repos-search -u <user> -q <query> -E               # treat query as regex
#   github-repos-search -u <user> -q <query> -o out.txt       # custom output
#   github-repos-search --help                                # show help
#
# Searches across repo metadata (name, description, homepage, topics, language).
# Case-insensitive substring match by default. Use -E to interpret the query as
# an extended regex. Use -c for case-sensitive matching.
#
# Output (stdout): one row per matched field, grouped by repo (sorted).
# Output (file): unique list of repo URLs, one per line.
#
# Requires: gh CLI (authenticated), jq

set -u

GH_USER=""
VISIBILITY="all"
INCLUDE_FORKS=0
QUERY=""
CASE_SENSITIVE=0
REGEX=0
OUTPUT_FILE=""

show_usage() {
    sed -n '2,/^$/p' "$0" | sed -E 's/^# ?//'
}

if [[ $# -eq 0 && -t 0 ]]; then
    show_usage
    exit 0
fi

while [[ $# -gt 0 ]]; do
    case "$1" in
        -u|--user)
            [[ -z "${2:-}" ]] && { echo "ERROR: --user requires a value" >&2; exit 1; }
            GH_USER="$2"; shift 2 ;;
        -q|--query)
            [[ -z "${2:-}" ]] && { echo "ERROR: --query requires a value" >&2; exit 1; }
            QUERY="$2"; shift 2 ;;
        -v|--visibility)
            [[ -z "${2:-}" ]] && { echo "ERROR: --visibility requires a value" >&2; exit 1; }
            VISIBILITY="$2"; shift 2 ;;
        -F|--include-forks)
            INCLUDE_FORKS=1; shift ;;
        -c|--case-sensitive)
            CASE_SENSITIVE=1; shift ;;
        -E|--regex)
            REGEX=1; shift ;;
        -o|--output)
            [[ -z "${2:-}" ]] && { echo "ERROR: --output requires a path" >&2; exit 1; }
            OUTPUT_FILE="$2"; shift 2 ;;
        -h|--help)
            show_usage; exit 0 ;;
        *)
            echo "Unknown argument: $1 (use --help)" >&2; exit 1 ;;
    esac
done

if [[ -z "$GH_USER" ]]; then
    echo "ERROR: -u <user> is required" >&2; exit 1
fi
if [[ -z "$QUERY" ]]; then
    echo "ERROR: -q <query> is required" >&2; exit 1
fi

if ! command -v gh > /dev/null 2>&1; then
    echo "ERROR: gh CLI not found" >&2; exit 1
fi
if ! command -v jq > /dev/null 2>&1; then
    echo "ERROR: jq not found. Install with: brew install jq" >&2; exit 1
fi

case "$VISIBILITY" in
    public|private|all) ;;
    *) echo "ERROR: invalid visibility '$VISIBILITY' (use: public, private, all)" >&2; exit 1 ;;
esac

if [[ -z "$OUTPUT_FILE" ]]; then
    TIMESTAMP="$(date +%Y-%m-%d_%H-%M-%S)"
    # sanitize query for filename (keep alphanumeric, dash, underscore)
    SAFE_Q=$(echo "$QUERY" | tr -c '[:alnum:]_-' '_' | sed 's/__*/_/g; s/^_//; s/_$//')
    [[ -z "$SAFE_Q" ]] && SAFE_Q="query"
    OUTPUT_FILE="$PWD/search-$GH_USER-$SAFE_Q""_$TIMESTAMP.txt"
fi

# colors (tty only)
if [[ -t 1 ]]; then
    C_RESET=$'\033[0m'; C_BOLD=$'\033[1m'
    C_GREEN=$'\033[32m'
    C_CYAN=$'\033[36m'; C_DIM=$'\033[90m'
else
    C_RESET=""; C_BOLD=""; C_GREEN=""; C_CYAN=""; C_DIM=""
fi

vis_args=()
[[ "$VISIBILITY" != "all" ]] && vis_args=(--visibility "$VISIBILITY")

echo "${C_BOLD}User:${C_RESET}        $GH_USER"
echo "${C_BOLD}Visibility:${C_RESET}  $VISIBILITY"
echo "${C_BOLD}Forks:${C_RESET}       $([[ $INCLUDE_FORKS == 1 ]] && echo included || echo excluded)"
echo "${C_BOLD}Query:${C_RESET}       $QUERY"
echo "${C_BOLD}Match:${C_RESET}       $([[ $CASE_SENSITIVE == 1 ]] && echo case-sensitive || echo case-insensitive) / $([[ $REGEX == 1 ]] && echo regex || echo substring)"
echo "${C_BOLD}Output:${C_RESET}      $OUTPUT_FILE"
echo

# Fetch metadata for all repos as (slug \t field \t value) triples
fork_filter='true'
[[ "$INCLUDE_FORKS" == "0" ]] && fork_filter='.isFork == false'

triples=$(gh repo list "$GH_USER" "${vis_args[@]}" --limit 1000 \
    --json nameWithOwner,description,homepageUrl,repositoryTopics,primaryLanguage,isFork \
    --jq "
        .[] | select($fork_filter) |
        . as \$r |
        [
            [\$r.nameWithOwner, \"name\",        \$r.nameWithOwner],
            [\$r.nameWithOwner, \"description\", (\$r.description // \"\")],
            [\$r.nameWithOwner, \"homepage\",    (\$r.homepageUrl // \"\")],
            [\$r.nameWithOwner, \"topics\",      ((\$r.repositoryTopics // []) | map(.name) | join(\",\"))],
            [\$r.nameWithOwner, \"language\",    (\$r.primaryLanguage.name // \"\")]
        ][] | select(.[2] != \"\") | @tsv
    ")

total_repos=$(echo "$triples" | cut -f1 | sort -u | wc -l | tr -d ' ')

# Build grep flags
grep_flags=(-E)
[[ "$CASE_SENSITIVE" == "0" ]] && grep_flags+=(-i)
[[ "$REGEX" == "0" ]] && grep_flags=(-F)
[[ "$REGEX" == "0" && "$CASE_SENSITIVE" == "0" ]] && grep_flags=(-Fi)

# Filter to lines where the value column contains the query
matches=$(echo "$triples" | awk -F'\t' '{print $3 "\t" $0}' \
    | grep "${grep_flags[@]}" -- "$QUERY" \
    | cut -f2-)

if [[ -z "$matches" ]]; then
    echo "No matches across $total_repos repos."
    : > "$OUTPUT_FILE"
    exit 0
fi

# Pretty print — group by slug
current_slug=""
echo "$matches" | sort | while IFS=$'\t' read -r slug field value; do
    if [[ "$slug" != "$current_slug" ]]; then
        [[ -n "$current_slug" ]] && echo
        printf "${C_BOLD}${C_CYAN}%s${C_RESET}\n" "$slug"
        current_slug="$slug"
    fi
    printf "  ${C_GREEN}%-12s${C_RESET} ${C_DIM}|${C_RESET} %s\n" "$field" "$value"
done
echo

# Save unique repo URLs to file
echo "$matches" | cut -f1 | sort -u \
    | awk '{print "https://github.com/" $0}' > "$OUTPUT_FILE"

matched_repos=$(wc -l < "$OUTPUT_FILE" | tr -d ' ')
echo "${C_BOLD}Found $matched_repos/$total_repos repos matching '$QUERY'.${C_RESET}"
echo "Written to: $OUTPUT_FILE"
