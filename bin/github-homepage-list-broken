#!/usr/bin/env bash
# Usage:
#   github-homepage-list-broken -u <username>              # all repos (forks excluded)
#   github-homepage-list-broken -u <username> -v public    # only public
#   github-homepage-list-broken -u <username> -v private   # only private
#   github-homepage-list-broken -u <username> -F           # include forks
#   github-homepage-list-broken -u <username> -r           # save repo URLs (github.com/owner/repo)
#   github-homepage-list-broken -u <username> -o out.txt   # custom output file
#   github-homepage-list-broken --help                     # show help
#
# Lists repositories whose homepage URL is broken (HTTP status outside 2xx/3xx)
# and writes them to a file. Default mode: broken homepage URLs.
# With -r / --repo-url: repository URLs instead (chainable with homepage-clear.sh).
#
# Env:
#   CONCURRENCY=10   parallelism for URL checks
#   TIMEOUT=15       per-request timeout in seconds
#
# Requires: gh CLI (authenticated), curl

set -u

GH_USER=""
VISIBILITY="all"
INCLUDE_FORKS=0
OUTPUT_FILE=""
OUTPUT_MODE="homepage"    # homepage | repo
CONCURRENCY="${CONCURRENCY:-10}"
TIMEOUT="${TIMEOUT:-15}"

show_usage() {
    sed -n '2,/^$/p' "$0" | sed -E 's/^# ?//'
}

if [[ $# -eq 0 && -t 0 ]]; then
    show_usage
    exit 0
fi

while [[ $# -gt 0 ]]; do
    case "$1" in
        -u|--user)
            [[ -z "${2:-}" ]] && { echo "ERROR: --user requires a username" >&2; exit 1; }
            GH_USER="$2"; shift 2 ;;
        -v|--visibility)
            [[ -z "${2:-}" ]] && { echo "ERROR: --visibility requires a value" >&2; exit 1; }
            VISIBILITY="$2"; shift 2 ;;
        -F|--include-forks)
            INCLUDE_FORKS=1; shift ;;
        -r|--repo-url)
            OUTPUT_MODE="repo"; shift ;;
        -o|--output)
            [[ -z "${2:-}" ]] && { echo "ERROR: --output requires a path" >&2; exit 1; }
            OUTPUT_FILE="$2"; shift 2 ;;
        -h|--help)
            show_usage; exit 0 ;;
        *)
            echo "Unknown argument: $1 (use --help)" >&2; exit 1 ;;
    esac
done

if [[ -z "$GH_USER" ]]; then
    echo "ERROR: -u <user> is required" >&2
    show_usage
    exit 1
fi

if ! command -v gh > /dev/null 2>&1; then
    echo "ERROR: gh CLI not found. Install with: brew install gh" >&2
    exit 1
fi

case "$VISIBILITY" in
    public|private|all) ;;
    *) echo "ERROR: invalid visibility '$VISIBILITY' (use: public, private, all)" >&2; exit 1 ;;
esac

if [[ -z "$OUTPUT_FILE" ]]; then
    TIMESTAMP="$(date +%Y-%m-%d_%H-%M-%S)"
    if [[ "$OUTPUT_MODE" == "homepage" ]]; then
        OUTPUT_FILE="$PWD/broken-homepages-$GH_USER""_$TIMESTAMP.txt"
    else
        OUTPUT_FILE="$PWD/broken-homepages-repos-$GH_USER""_$TIMESTAMP.txt"
    fi
fi

# colors (tty only)
if [[ -t 1 ]]; then
    C_RESET=$'\033[0m'; C_BOLD=$'\033[1m'
    C_GREEN=$'\033[32m'; C_RED=$'\033[31m'; C_DIM=$'\033[90m'
else
    C_RESET=""; C_BOLD=""; C_GREEN=""; C_RED=""; C_DIM=""
fi

paint_status() {
    local status="$1"
    local padded
    printf -v padded "%-6s" "$status"
    case "$status" in
        OK)     printf "%s%s%s" "$C_GREEN" "$padded" "$C_RESET" ;;
        BROKEN) printf "%s%s%s" "$C_RED"   "$padded" "$C_RESET" ;;
        *)      printf "%s%s%s" "$C_DIM"   "$padded" "$C_RESET" ;;
    esac
}

vis_args=()
[[ "$VISIBILITY" != "all" ]] && vis_args=(--visibility "$VISIBILITY")

jq_filter='.[]'
[[ "$INCLUDE_FORKS" == "0" ]] && jq_filter='.[] | select(.isFork==false)'
jq_filter="$jq_filter | select(.homepageUrl != null and .homepageUrl != \"\") | \"\(.nameWithOwner)\t\(.homepageUrl)\""

echo "${C_BOLD}User:${C_RESET}        $GH_USER"
echo "${C_BOLD}Visibility:${C_RESET}  $VISIBILITY"
echo "${C_BOLD}Forks:${C_RESET}       $([[ $INCLUDE_FORKS == 1 ]] && echo included || echo excluded)"
echo "${C_BOLD}Mode:${C_RESET}        $OUTPUT_MODE"
echo "${C_BOLD}Concurrency:${C_RESET} $CONCURRENCY"
echo "${C_BOLD}Timeout:${C_RESET}     ${TIMEOUT}s"
echo "${C_BOLD}Output:${C_RESET}      $OUTPUT_FILE"
echo

# 1. Fetch repos with non-empty homepage
entries=$(gh repo list "$GH_USER" "${vis_args[@]}" --limit 1000 \
    --json nameWithOwner,isFork,homepageUrl --jq "$jq_filter")

if [[ -z "$entries" ]]; then
    echo "No repos with a homepage set."
    : > "$OUTPUT_FILE"
    exit 0
fi

total=$(echo "$entries" | wc -l | tr -d ' ')
echo "Checking $total homepage URLs..."
echo

# 2. Check each homepage URL in parallel
check_entry() {
    local slug="$1"
    local url="$2"
    local code
    code=$(curl -s -o /dev/null -L -w "%{http_code}" \
        --max-time "$TIMEOUT" \
        -A "Mozilla/5.0 (github-homepage-list-broken)" \
        "$url" 2>/dev/null)
    code="${code:-000}"

    if [[ "$code" =~ ^(2|3)[0-9][0-9]$ ]]; then
        printf "OK\t%s\t%s\t%s\n" "$code" "$slug" "$url"
    else
        printf "BROKEN\t%s\t%s\t%s\n" "$code" "$slug" "$url"
    fi
}
export -f check_entry
export TIMEOUT

results=$(echo "$entries" \
    | tr '\t' '\n' \
    | xargs -n 2 -P "$CONCURRENCY" bash -c 'check_entry "$1" "$2"' _)

# 3. Print sorted
echo "$results" | sort | while IFS=$'\t' read -r status code slug url; do
    [[ -z "$status" ]] && continue
    printf "%s  %5s  %-50s  %s\n" "$(paint_status "$status")" "$code" "$slug" "$url"
done

# 4. Save broken entries to file
broken=$(echo "$results" | awk -F'\t' '$1=="BROKEN"')

if [[ "$OUTPUT_MODE" == "repo" ]]; then
    echo "$broken" | awk -F'\t' 'NF>=3 { print "https://github.com/" $3 }' | sort -u > "$OUTPUT_FILE"
else
    echo "$broken" | awk -F'\t' 'NF>=4 { print $4 }' | sort -u > "$OUTPUT_FILE"
fi

ok=$(echo "$results" | grep -c '^OK' || true)
fail=$(echo "$results" | grep -c '^BROKEN' || true)

echo
echo "${C_BOLD}Summary:${C_RESET} OK=$ok  BROKEN=$fail  TOTAL=$total"
echo "Written $(wc -l < "$OUTPUT_FILE" | tr -d ' ') broken entries to: $OUTPUT_FILE"
