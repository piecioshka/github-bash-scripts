#!/usr/bin/env bash
# Usage:
#   github-pages-list -u <username>                      # all repos (forks excluded)
#   github-pages-list -u <username> -v public            # only public
#   github-pages-list -u <username> -v private           # only private
#   github-pages-list -u <username> -F                   # include forks
#   github-pages-list -u <username> -r                   # save repo URLs (github.com/owner/repo)
#   github-pages-list -u <username> -o pages.txt         # custom output file
#   github-pages-list --help                             # show help
#
# Lists repositories that have GitHub Pages enabled and writes their URLs
# to a file (one URL per line). Default mode: Pages URLs (owner.github.io/repo).
# With -r / --repo-url: repository URLs (github.com/owner/repo).
#
# Requires: gh CLI (authenticated)

set -u

GH_USER=""
VISIBILITY="all"
INCLUDE_FORKS=0
OUTPUT_FILE=""
OUTPUT_MODE="pages"     # pages | repo
CONCURRENCY="${CONCURRENCY:-10}"

show_usage() {
    sed -n '2,/^$/p' "$0" | sed -E 's/^# ?//'
}

if [[ $# -eq 0 && -t 0 ]]; then
    show_usage
    exit 0
fi

while [[ $# -gt 0 ]]; do
    case "$1" in
        -u|--user)
            [[ -z "${2:-}" ]] && { echo "ERROR: --user requires a username" >&2; exit 1; }
            GH_USER="$2"; shift 2 ;;
        -v|--visibility)
            [[ -z "${2:-}" ]] && { echo "ERROR: --visibility requires a value" >&2; exit 1; }
            VISIBILITY="$2"; shift 2 ;;
        -F|--include-forks)
            INCLUDE_FORKS=1; shift ;;
        -r|--repo-url)
            OUTPUT_MODE="repo"; shift ;;
        -o|--output)
            [[ -z "${2:-}" ]] && { echo "ERROR: --output requires a path" >&2; exit 1; }
            OUTPUT_FILE="$2"; shift 2 ;;
        -h|--help)
            show_usage; exit 0 ;;
        *)
            echo "Unknown argument: $1 (use --help)" >&2; exit 1 ;;
    esac
done

if [[ -z "$GH_USER" ]]; then
    echo "ERROR: -u <user> is required" >&2
    show_usage
    exit 1
fi

if ! command -v gh > /dev/null 2>&1; then
    echo "ERROR: gh CLI not found. Install with: brew install gh" >&2
    exit 1
fi

case "$VISIBILITY" in
    public|private|all) ;;
    *) echo "ERROR: invalid visibility '$VISIBILITY' (use: public, private, all)" >&2; exit 1 ;;
esac

if [[ -z "$OUTPUT_FILE" ]]; then
    TIMESTAMP="$(date +%Y-%m-%d_%H-%M-%S)"
    OUTPUT_FILE="$PWD/${OUTPUT_MODE}-links-$GH_USER""_$TIMESTAMP.txt"
fi

# colors (tty only)
if [[ -t 1 ]]; then
    C_RESET=$'\033[0m'; C_BOLD=$'\033[1m'
    C_GREEN=$'\033[32m'; C_DIM=$'\033[90m'
else
    C_RESET=""; C_BOLD=""; C_GREEN=""; C_DIM=""
fi

vis_args=()
[[ "$VISIBILITY" != "all" ]] && vis_args=(--visibility "$VISIBILITY")

jq_filter='.[]'
[[ "$INCLUDE_FORKS" == "0" ]] && jq_filter='.[] | select(.isFork==false)'
jq_filter="$jq_filter | .nameWithOwner"

echo "${C_BOLD}User:${C_RESET}       $GH_USER"
echo "${C_BOLD}Visibility:${C_RESET} $VISIBILITY"
echo "${C_BOLD}Forks:${C_RESET}      $([[ $INCLUDE_FORKS == 1 ]] && echo included || echo excluded)"
echo "${C_BOLD}Mode:${C_RESET}       $OUTPUT_MODE"
echo "${C_BOLD}Concurrency:${C_RESET} $CONCURRENCY"
echo "${C_BOLD}Output:${C_RESET}     $OUTPUT_FILE"
echo

repos=$(gh repo list "$GH_USER" "${vis_args[@]}" --limit 1000 \
    --json nameWithOwner,isFork --jq "$jq_filter")

if [[ -z "$repos" ]]; then
    echo "No repos match the filter."
    : > "$OUTPUT_FILE"
    exit 0
fi

total=$(echo "$repos" | wc -l | tr -d ' ')
echo "Checking $total repos for GitHub Pages..."
echo

check_pages() {
    local slug="$1"
    local html_url
    if html_url=$(gh api "repos/$slug/pages" --jq '.html_url' 2>/dev/null) \
        && [[ -n "$html_url" && "$html_url" != "null" ]]; then
        printf "%s\t%s\n" "$slug" "$html_url"
    fi
}
export -f check_pages

results=$(echo "$repos" \
    | xargs -n 1 -P "$CONCURRENCY" -I {} bash -c 'check_pages "$@"' _ {})

# Pretty print
if [[ -n "$results" ]]; then
    while IFS=$'\t' read -r slug url; do
        [[ -z "$slug" ]] && continue
        printf "${C_GREEN}✓${C_RESET} %-50s ${C_DIM}→${C_RESET} %s\n" "$slug" "$url"
    done <<< "$(echo "$results" | sort)"
fi

# Save URLs to file (pages URL or repo URL depending on mode)
if [[ "$OUTPUT_MODE" == "repo" ]]; then
    echo "$results" | cut -f1 | grep -v '^$' | sort -u \
        | awk '{print "https://github.com/" $0}' > "$OUTPUT_FILE"
else
    echo "$results" | cut -f2 | grep -v '^$' | sort -u > "$OUTPUT_FILE"
fi

found=$(wc -l < "$OUTPUT_FILE" | tr -d ' ')
echo
echo "${C_BOLD}Found $found/$total repos with GitHub Pages.${C_RESET}"
echo "Written to: $OUTPUT_FILE"
